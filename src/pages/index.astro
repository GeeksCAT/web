---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Hero from '@sections/marketing/Hero.astro';
import HowItWorks from '@sections/marketing/HowItWorks.astro';
import FeaturesSection from '@sections/marketing/FeaturesSection.astro';
import CTA from '@sections/marketing/CTA.astro';
import Newsletter from '@sections/marketing/Newsletter.astro';
import { siteConfig } from '@/config';

const features = [
  {
    icon: 'lucide:calendar',
    title: 'Monthly Meetups',
    description: 'Join us every month for tech talks, workshops, and networking with the local developer community.',
  },
  {
    icon: 'lucide:users',
    title: 'Community Events',
    description: 'Hackathons, code sprints, and social events to connect with other tech enthusiasts.',
  },
  {
    icon: 'lucide:code-2',
    title: 'Workshops',
    description: 'Learn new technologies and share your knowledge with hands-on coding sessions.',
  },
  {
    icon: 'lucide:network',
    title: 'Networking',
    description: 'Connect with developers, designers, and tech professionals from across Catalonia.',
  },
  {
    icon: 'lucide:book-open',
    title: 'Knowledge Sharing',
    description: 'Share experiences, best practices, and learn from industry experts.',
  },
  {
    icon: 'lucide:globe',
    title: 'Open Source',
    description: 'Collaborate on open source projects and contribute to the tech community.',
  },
];

const steps = [
  {
    title: 'Join an Event',
    description: 'Attend one of our monthly meetups or events. Everyone is welcome!',
    icon: 'lucide:calendar-check',
  },
  {
    title: 'Connect',
    description: 'Meet other developers and tech enthusiasts in a friendly environment.',
    icon: 'lucide:user-plus',
  },
  {
    title: 'Learn & Share',
    description: 'Learn new technologies, share your knowledge, and grow together.',
    icon: 'lucide:lightbulb',
  },
];
---

<MarketingLayout
  title={`${siteConfig.name} - ${siteConfig.description}`}
  description={siteConfig.description}
>
  <Hero
    title="Geeks.CAT"
    subtitle="The technology and computing association of Catalonia. We bring together developers, designers, and tech enthusiasts to learn, share, and connect."
    primaryCTA={{ label: 'Join Us', href: '/join' }}
    secondaryCTA={{ label: 'View Events', href: '/events' }}
  />

  <HowItWorks
    title="How it works"
    subtitle="Join our community in three simple steps"
    steps={steps}
    variant="horizontal"
    background="muted"
  />

  <FeaturesSection
    title="What we do"
    subtitle="Building a strong tech community in Catalonia through events, learning, and collaboration."
    features={features}
    background="default"
  />

  <CTA
    title="Join Geeks.CAT"
    description="Become part of our growing community of tech enthusiasts. All skill levels welcome!"
    action={{ label: 'Join Now', href: '/join' }}
  />

  <Newsletter />
</MarketingLayout>
